# Normalize text files across Windows/macOS/Linux.
* text=auto eol=lf

# MATLAB and project text files.
*.m text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.mat binary
*.fig binary
*.slx binary
*.mlx binary
